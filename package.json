{
  "name": "heylo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- concurrently -k -n api,web -c blue,magenta \"npm run start:dev -w heylo-api\" \"npm run dev -w heylo-web\"",
    "dev:api": "dotenv -e .env -- npm run start:dev -w heylo-api",
    "dev:web": "dotenv -e .env -- npm run dev -w heylo-web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^7.4.4"
  }
}
