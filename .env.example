AWS_PROFILE=heylo-dev
NEXT_PUBLIC_AWS_REGION=us-east-2
NEXT_PUBLIC_AWS_ACCOUNT_ID=
NEXT_PUBLIC_AWS_COGNITO_IDENTITY_POOL_ID=
NEXT_PUBLIC_AWS_COGNITO_USER_AUTH_CLIENT_ID=

# Cloud service URLs — overridden with localhost by the CLI for selected services
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APPSYNC_GRAPHQL_ENDPOINT=

# DB base (host/user/pass come from .env.dev or .env.local)
DB_PORT=3306
DB_NAME=heylo
