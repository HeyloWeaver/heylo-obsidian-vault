AWS_PROFILE=heylo-dev
NEXT_PUBLIC_AWS_REGION=us-east-2
NEXT_PUBLIC_AWS_ACCOUNT_ID=
NEXT_PUBLIC_AWS_COGNITO_IDENTITY_POOL_ID=
NEXT_PUBLIC_AWS_COGNITO_USER_AUTH_CLIENT_ID=

# Cloud service URLs — used when a service is NOT running locally.
# `npx heylo` automatically overrides these with localhost values for
# whichever services you choose to start. Set these to your dev cloud URLs.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APPSYNC_GRAPHQL_ENDPOINT=

# MySQL (Nest API + local Go AppSync). `dotenv -e .env` loads this at the vault root.
# For the same RDS host as `heylo-api`, copy DB_* from backend/src/config/development.env
# or set a single DSN for Go only:
# APPSYNC_MYSQL_DSN=user:pass@tcp(host:3306)/heylo?parseTime=true&loc=UTC
DB_HOST=
DB_USER=
DB_PASS=
DB_PORT=3306
DB_NAME=heylo